#: blocks/event-archive-meta/block.json
msgctxt "block title"
msgid "Event archive meta"
msgstr "Méta archive événement"

#: blocks/event-archive-meta/block.json
msgctxt "block description"
msgid "Roles and location row for event archive list items (.entry-meta)."
msgstr ""
"Ligne rôles + lieu pour les items de l’archive événement (.entry-meta)."

#: blocks/event-external-link/block.json
msgctxt "block title"
msgid "Event external link"
msgstr "Lien externe de l’événement"

#: blocks/event-external-link/block.json
msgctxt "block description"
msgid "Outputs event_link as .entry-links when set."
msgstr "Affiche event_link en tant que .entry-links lorsque défini."

#: blocks/event-filter/block.json
msgctxt "block title"
msgid "Event role filters"
msgstr "Filtres rôles événements"

