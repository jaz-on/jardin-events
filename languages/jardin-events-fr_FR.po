msgstr ""
"Liens chips pour filtrer l’archive des événements par rôle (?event_role=)."

#: blocks/event-inline-date/block.json
msgctxt "block title"
msgid "Event date (inline)"
msgstr "Date événement (en ligne)"

#: blocks/event-inline-date/block.json
msgctxt "block description"
